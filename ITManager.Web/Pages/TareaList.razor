@page "/tareas"
@using ITManager.Web.Models
@using ITManager.Web.Services
@inject ITareaService TareaService

<PageTitle>Tareas</PageTitle>

<h1>Consulta de Tareas</h1>

<div class="mb-3 d-flex flex-wrap gap-2 align-items-end">
    <div>
        <label for="status">Status</label>
        <select id="status" class="form-select" @bind="statusFilter">
            <option value="">Todos</option>
            <option value="pending">pending</option>
            <option value="sent">sent</option>
            <option value="failed">failed</option>
        </select>
    </div>

    <div>
        <label for="uen">Uen</label>
        <input id="uen" class="form-control" @bind="uenFilter" />
    </div>

    <div>
        <label for="desde">Desde</label>
        <input id="desde" type="date" class="form-control" @bind="desdeFilterText" />
    </div>

    <div>
        <label for="hasta">Hasta</label>
        <input id="hasta" type="date" class="form-control" @bind="hastaFilterText" />
    </div>

    <div>
        <button class="btn btn-primary" @onclick="HandleSearchAsync">Buscar</button>
    </div>
</div>

@if (isLoading)
{
    <p>Cargando tareas...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else if (!items.Any())
{
    <p>No se encontraron tareas.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>CreatedAt</th>
                <th>Uen</th>
                <th>NombreTarea</th>
                <th>Status</th>
                <th>Attempts</th>
                <th>ProcessedAt</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in items)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@item.Uen</td>
                    <td>@item.NombreTarea</td>
                    <td>@item.Status</td>
                    <td>@item.Attempts</td>
                    <td>@(item.ProcessedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="d-flex gap-2">
    <button class="btn btn-secondary" @onclick="HandlePreviousAsync" disabled="@(page == 1 || isLoading)">Anterior</button>
    <button class="btn btn-secondary" @onclick="HandleNextAsync" disabled="@(isLoading || items.Count < pageSize)">Siguiente</button>
    <span>Página @page</span>
</div>

@code {
    private List<TareaItemModel> items = new();
    private bool isLoading;
    private string? errorMessage;

    private string? statusFilter;
    private string? uenFilter;
    private string? desdeFilterText;
    private string? hastaFilterText;

    private int page = 1;
    private const int pageSize = 200;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task HandleSearchAsync()
    {
        page = 1;
        await LoadAsync();
    }

    private async Task HandlePreviousAsync()
    {
        if (page == 1)
            return;

        page--;
        await LoadAsync();
    }

    private async Task HandleNextAsync()
    {
        page++;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            items = await TareaService.GetAllAsync(
                statusFilter,
                uenFilter,
                ParseDate(desdeFilterText),
                ParseDate(hastaFilterText),
                page,
                pageSize);
        }
        catch (Exception ex)
        {
            items = new List<TareaItemModel>();
            errorMessage = $"Error al consultar tareas: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static DateTime? ParseDate(string? dateText)
    {
        if (DateTime.TryParse(dateText, out var parsed))
            return parsed;

        return null;
    }
}
