{
    "ConnectionStrings": {
        "DefaultConnection": "REEMPLAZAR_CON_CONNECTION_STRING"
    },
    "ServiceBus": {
        "ConnectionString": "REEMPLAZAR_CON_CONNECTION_STRING",
        "ToWooCommerceQueue": "itmanager-to-woocommerce",
        "FromWooCommerceQueue": "itmanager-from-woocommerce"
    },
    "WooCommerce": {
        "BaseUrl": "REEMPLAZAR_CON_CONNECTION_URL",
        "ConsumerKey": "REEMPLAZAR_CON_CONSUMER_KEY",
        "ConsumerSecret": "REEMPLAZAR_CON_CONSUMER_SECRET",
        "TimeoutSeconds": 10
    },
    "Worker": {
        "PollingIntervalSeconds": 10,
        "BatchSize": 50
    },
    "Serilog": {
        "MinimumLevel": "Information"
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.EntityFrameworkCore": "Warning"
        }
    }
}
